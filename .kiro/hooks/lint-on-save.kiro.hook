{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on TypeScript and TSX files whenever they are saved in the frontend",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/**/*.ts",
      "frontend/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd frontend && npm run lint"
  }
}